#!/usr/bin/env bash
#
# stages-thermo pre-push hook — local CI lint gate.
#
# Mirrors the first step of the CI `lint (fmt + clippy)` job so a formatting
# slip is caught here instead of going red in GitHub Actions (where a fmt
# failure also skips clippy entirely). Runs `cargo fmt --check` over the whole
# workspace and blocks the push on any diff.
#
# Note: clippy is NOT run here (same reason as vle: the local rustc can trip a
# pyo3 lint across #[pyfunction] under `clippy -D warnings` that CI's pinned
# toolchain does not). fmt is the lint gate we can — and therefore do —
# enforce locally.
#
# This repo carries no infrastructure topology (hostnames, IPs, tokens), so
# there is no private-data gate here — only the fmt gate. Keep this comment as
# the placeholder-only marker: if infra ever lands, clone the private-data
# pattern array from ~/.claude-config/hooks/pre-push before pushing it.
#
# Activate with:  git config core.hooksPath hooks
# Bypass (discouraged) with:  git push --no-verify

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

# No Rust toolchain on this machine → skip rather than block (e.g. a docs-only
# clone). CI is still authoritative.
if ! command -v cargo >/dev/null 2>&1; then
    echo "pre-push: cargo not found — skipping fmt check (CI will still enforce it)." >&2
    exit 0
fi

echo "pre-push: cargo fmt --check ..." >&2
if ! cargo fmt --check >/dev/null 2>&1; then
    echo >&2
    echo "ABORT: 'cargo fmt --check' found unformatted code." >&2
    echo "       Run 'cargo fmt' to fix it, commit, then push again." >&2
    echo "       (The CI lint job runs the same check and would fail.)" >&2
    echo >&2
    echo "Offending diff:" >&2
    cargo fmt --check >&2 || true
    exit 1
fi

echo "pre-push: fmt clean." >&2
exit 0
